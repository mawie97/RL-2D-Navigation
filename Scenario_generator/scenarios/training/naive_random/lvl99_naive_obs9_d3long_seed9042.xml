<mujoco model="lvl99_naive_obs9_d3long_seed9042">
    <compiler angle="degree" coordinate="local" inertiafromgeom="true"/>
    <option integrator="RK4" timestep="0.01"/>

    <asset>
        <texture builtin="gradient" height="100" rgb1="0.6 0.8 1" rgb2="0 0 0" type="skybox" width="100"/>
        <texture name="floor_texture" type="2d" builtin="checker" width="100" height="100" rgb1="0 0 0" rgb2="0.8 0.8 0.8"/>
        <material name="MatPlane" reflectance="0.5" shininess="1" specular="1" texrepeat="10 10" texture="floor_texture"/>
    </asset>
    
    <!-- Excluding the contact between the agent and the goal, and the agent and the floor -->
    <contact>
        <exclude body1="agent" body2="goal"/>
        <exclude body1 = "agent" body2 = "floor"/>
    </contact>

    <extension>
        <plugin plugin = "mujoco.pid">
            <instance name = "pid1">
                <config key="kp" value="2"/>
                <config key="ki" value="0"/>
                <config key="kd" value="55"/>
            </instance>
        </plugin>
    </extension>


    <worldbody>
        <light cutoff="100" diffuse="1 1 1" dir="-0 0 -1.3" directional="true" exponent="1" pos="0 0 1.3" specular=".1 .1 .1"/>
        <body name="floor" pos="0 0 0">
            <geom name="floor_geom" type="plane" size="20 20 0.1" material="MatPlane"/>
        </body>
        

                <body name="goal" pos="0.0000 0.0000 0">
            <geom name="goal_geom" type="plane" size="0.5 0.5 1" pos="0 0 0" rgba="1 0 0 1"/>
        </body>
        

                <body name="agent" pos="12.0000 12.0000 0.250">
            <joint name="j1" type="slide" axis ="1 0 0 "/>
            <joint name="j2" type="slide" axis ="0 1 0 "/>
            <geom name="agent_geom" type="cylinder" size="0.25 0.25 0.250" rgba="1 1 0 1"/>
        </body>


        <body name="obstacle1" pos="-12.0465 13.9169 0.250">  <geom name="obstacle1_geom" type="box" size="0.9000 0.9000 0.250" rgba="0 1 0 1"/></body>
        <body name="obstacle2" pos="3.9653 13.9456 0.250">  <geom name="obstacle2_geom" type="box" size="0.9000 0.9000 0.250" rgba="0 1 0 1"/></body>
        <body name="obstacle3" pos="-2.0561 5.9017 0.250">  <geom name="obstacle3_geom" type="box" size="0.9000 0.9000 0.250" rgba="0 1 0 1"/></body>
        <body name="obstacle4" pos="1.9559 6.0025 0.250">  <geom name="obstacle4_geom" type="box" size="0.9000 0.9000 0.250" rgba="0 1 0 1"/></body>
        <body name="obstacle5" pos="-1.9936 -2.0388 0.250">  <geom name="obstacle5_geom" type="box" size="0.9000 0.9000 0.250" rgba="0 1 0 1"/></body>
        <body name="obstacle6" pos="13.9649 -2.0688 0.250">  <geom name="obstacle6_geom" type="box" size="0.9000 0.9000 0.250" rgba="0 1 0 1"/></body>
        <body name="obstacle7" pos="-3.9995 -5.9069 0.250">  <geom name="obstacle7_geom" type="box" size="0.9000 0.9000 0.250" rgba="0 1 0 1"/></body>
        <body name="obstacle8" pos="5.9596 -5.9042 0.250">  <geom name="obstacle8_geom" type="box" size="0.9000 0.9000 0.250" rgba="0 1 0 1"/></body>
        <body name="obstacle9" pos="9.9219 -7.9346 0.250">  <geom name="obstacle9_geom" type="box" size="0.9000 0.9000 0.250" rgba="0 1 0 1"/></body>


    </worldbody>

    <sensor>
<!-- SENSORS -->
    
        <distance name="dist1" geom1="agent_geom" geom2="obstacle1_geom" cutoff="1.5"/>
        <distance name="dist2" geom1="agent_geom" geom2="obstacle2_geom" cutoff="1.5"/>
        <distance name="dist3" geom1="agent_geom" geom2="obstacle3_geom" cutoff="1.5"/>
        <distance name="dist4" geom1="agent_geom" geom2="obstacle4_geom" cutoff="1.5"/>
        <distance name="dist5" geom1="agent_geom" geom2="obstacle5_geom" cutoff="1.5"/>
        <distance name="dist6" geom1="agent_geom" geom2="obstacle6_geom" cutoff="1.5"/>
        <distance name="dist7" geom1="agent_geom" geom2="obstacle7_geom" cutoff="1.5"/>
        <distance name="dist8" geom1="agent_geom" geom2="obstacle8_geom" cutoff="1.5"/>
        <distance name="dist9" geom1="agent_geom" geom2="obstacle9_geom" cutoff="1.5"/>
</sensor>

    <actuator>
        <plugin joint="j1" plugin="mujoco.pid" instance="pid1" />
        <plugin joint="j2" plugin="mujoco.pid" instance="pid1"/>
    </actuator>
</mujoco>
